{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2017"],
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@figma", "./node_modules/@types"],
    "types": ["@figma/plugin-typings"],
    "noEmit": true
  },
  "include": ["src/code.ts"]
}
